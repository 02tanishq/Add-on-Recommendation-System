import os
import json
import time
import numpy as np
import torch
import torch.nn as nn
from torch.utils.data import DataLoader
from torch.optim import AdamW
from torch.optim.lr_scheduler import OneCycleLR
from typing import Dict, Optional, Tuple

from training.ranking_dataset import build_ranking_dataloaders
from training.collate import get_collator
from training.losses import CartCompleteLoss
from models.Add_on_RecSys import AddOnRecSys


# ── utility helpers ───────────────────────────────────────────────────────────

class AverageMeter:
    """Tracks running average of a scalar metric."""

    def __init__(self, name: str):
        self.name = name
        self.reset()

    def reset(self):
        self.val = self.avg = self.sum = self.count = 0.0

    def update(self, val: float, n: int = 1):
        self.val    = val
        self.sum   += val * n
        self.count += n
        self.avg    = self.sum / self.count

    def __str__(self):
        return f"{self.name}: {self.avg:.4f}"


def format_time(seconds: float) -> str:
    m, s = divmod(int(seconds), 60)
    h, m = divmod(m, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


# ── ranking metrics ───────────────────────────────────────────────────────────

@torch.no_grad()
def compute_ranking_metrics(
    model:      AddOnRecSys,
    val_loader: DataLoader,
    device:     torch.device,
    k_values:   list = [5, 10],
) -> Dict[str, float]:
    """
    Computes HR@K, NDCG@K and MRR on the validation set.

    Strategy:
        For each sample we have one positive and one negative.
        We score both with the full ranker, then check whether
        the positive ranks above the negative.

        For a proper ranking evaluation we treat the batch as
        the candidate pool — each cart's positive is ranked
        against ALL negatives in the batch simultaneously.

    Metrics:
        HR@K   — Hit Rate  — did positive appear in top-K?
        NDCG@K — Normalised Discounted Cumulative Gain
        MRR    — Mean Reciprocal Rank of the positive item
    """
    model.eval()

    hr_meters   = {k: AverageMeter(f"HR@{k}")   for k in k_values}
    ndcg_meters = {k: AverageMeter(f"NDCG@{k}") for k in k_values}
    mrr_meter   = AverageMeter("MRR")

    for batch in val_loader:
        batch = {k: v.to(device) for k, v in batch.items()}
        B     = batch['cart_mask'].size(0)

        # ── score positive items ──────────────────────────────────────────────
        pos_scores = model(
            cart_item_idxs   = batch['cart_item_ids'],
            cart_text_embs   = batch['cart_text_embs'],
            cart_prices      = batch['cart_prices'],
            cart_food_groups = batch['cart_food_groups'],
            cart_popularity  = batch['cart_popularity'],
            cart_mask        = batch['cart_mask'],
            cand_item_idxs   = batch['pos_item_idx'],
            cand_text_embs   = batch['pos_text_emb'],
            cand_prices      = batch['pos_price'],
            cand_food_groups = batch['pos_food_group'],
            cand_popularity  = batch['pos_popularity'],
            cross_features   = batch['pos_cross_feats'],
            hour             = batch['hour'],
            dow              = batch['dow'],
            meal_period      = batch['meal_period'],
            restaurant_id    = batch['restaurant_id'],
            return_logit     = True,
        ).squeeze(-1)   # (B,)

        # ── score negative items ──────────────────────────────────────────────
        neg_scores = model(
            cart_item_idxs   = batch['cart_item_idxs'],
            cart_text_embs   = batch['cart_text_embs'],
            cart_prices      = batch['cart_prices'],
            cart_food_groups = batch['cart_food_groups'],
            cart_popularity  = batch['cart_popularity'],
            cart_mask        = batch['cart_mask'],
            cand_item_idxs   = batch['neg_item_idx'],
            cand_text_embs   = batch['neg_text_emb'],
            cand_prices      = batch['neg_price'],
            cand_food_groups = batch['neg_food_group'],
            cand_popularity  = batch['neg_popularity'],
            cross_features   = batch['neg_cross_feats'],
            hour             = batch['hour'],
            dow              = batch['dow'],
            meal_period      = batch['meal_period'],
            restaurant_id    = batch['restaurant_id'],
            return_logit     = True,
        ).squeeze(-1)   # (B,)

        # ── build score matrix for batch-level ranking ────────────────────────
        # Each cart i is ranked against all negatives in the batch
        # Score matrix: row i = [pos_score_i, all neg_scores in batch]
        # Shape: (B, B+1) — col 0 = positive, cols 1..B = all negatives
        score_matrix = torch.cat([
            pos_scores.unsqueeze(1),              # (B, 1)
            neg_scores.unsqueeze(0).expand(B, B), # (B, B)
        ], dim=1)   # (B, B+1)

        # Rank — lower rank = better (1 = top position)
        # argsort descending: position of each item in ranked list
        sorted_indices = score_matrix.argsort(
            dim=1, descending=True
        )   # (B, B+1)

        # Rank of positive item (col 0) for each cart
        pos_ranks = (sorted_indices == 0).nonzero(as_tuple=False)
        pos_ranks = pos_ranks[pos_ranks[:, 0].argsort()][:, 1] + 1  # (B,) 1-indexed

        # ── HR@K ─────────────────────────────────────────────────────────────
        for k in k_values:
            hits = (pos_ranks <= k).float()
            hr_meters[k].update(hits.mean().item(), n=B)

        # ── NDCG@K ───────────────────────────────────────────────────────────
        for k in k_values:
            in_top_k = (pos_ranks <= k).float()
            # DCG = 1/log2(rank+1) when item is in top-K
            dcg  = in_top_k / torch.log2(pos_ranks.float() + 1)
            # IDCG = 1/log2(2) since positive is always rank-1 in ideal
            idcg = torch.ones_like(dcg) / torch.log2(
                torch.tensor(2.0, device=device)
            )
            ndcg = (dcg / idcg).clamp(0, 1)
            ndcg_meters[k].update(ndcg.mean().item(), n=B)

        # ── MRR ──────────────────────────────────────────────────────────────
        rr = 1.0 / pos_ranks.float()   # reciprocal rank
        mrr_meter.update(rr.mean().item(), n=B)

    metrics = {
        f"HR@{k}":   hr_meters[k].avg   for k in k_values
    }
    metrics.update({
        f"NDCG@{k}": ndcg_meters[k].avg for k in k_values
    })
    metrics['MRR'] = mrr_meter.avg

    return metrics


# ── one training epoch ────────────────────────────────────────────────────────

def train_one_epoch(
    model:     AddOnRecSys,
    loader:    DataLoader,
    optimizer: torch.optim.Optimizer,
    scheduler: torch.optim.lr_scheduler._LRScheduler,
    criterion: CartCompleteLoss,
    device:    torch.device,
    epoch:     int,
    log_every: int = 50,
) -> Dict[str, float]:
    """
    Runs one full training epoch for the CartComplete ranker.

    For each batch:
        1. Score positive and negative candidates
        2. Compute BPR + Coverage loss
        3. Backward + gradient clip + step
    """
    model.train()

    meters = {
        'total':    AverageMeter('Total'),
        'bpr':      AverageMeter('BPR'),
        'coverage': AverageMeter('Coverage'),
        'hard_neg': AverageMeter('HardNeg'),
    }
    start = time.time()

    for step, batch in enumerate(loader):
        batch = {k: v.to(device) for k, v in batch.items()}
        B     = batch['cart_mask'].size(0)

        # ── score positive candidates ─────────────────────────────────────────
        pos_logits = model(
            cart_item_ids=batch['cart_item_idxs'],
            cart_text_embs   = batch['cart_text_embs'],
            cart_prices      = batch['cart_prices'],
            cart_food_groups = batch['cart_food_groups'],
            cart_popularity  = batch['cart_popularity'],
            cart_mask        = batch['cart_mask'],
            cand_item_id   = batch['pos_item_idx'],
            cand_text_embs   = batch['pos_text_emb'],
            cand_prices      = batch['pos_price'],
            cand_food_groups = batch['pos_food_group'],
            cand_popularity  = batch['pos_popularity'],
            cross_features   = batch['pos_cross_feats'],
            hour             = batch['hour'],
            dow              = batch['dow'],
            meal_period      = batch['meal_period'],
            restaurant_id    = batch['restaurant_id'],
            return_logit     = True,
        ).squeeze(-1)   # (B,)

        # ── score negative candidates ─────────────────────────────────────────
        neg_logits = model(
            cart_item_ids   = batch['cart_item_idxs'],
            cart_text_embs   = batch['cart_text_embs'],
            cart_prices      = batch['cart_prices'],
            cart_food_groups = batch['cart_food_groups'],
            cart_popularity  = batch['cart_popularity'],
            cart_mask        = batch['cart_mask'],
            cand_item_id   = batch['neg_item_idx'],
            cand_text_embs   = batch['neg_text_emb'],
            cand_prices      = batch['neg_price'],
            cand_food_groups = batch['neg_food_group'],
            cand_popularity  = batch['neg_popularity'],
            cross_features   = batch['neg_cross_feats'],
            hour             = batch['hour'],
            dow              = batch['dow'],
            meal_period      = batch['meal_period'],
            restaurant_id    = batch['restaurant_id'],
            return_logit     = True,
        ).squeeze(-1)   # (B,)

        # ── compute loss ──────────────────────────────────────────────────────
        # all_scores for hard negative mining = neg_logits from batch
        total_loss, loss_dict = criterion(
            pos_scores       = pos_logits,
            neg_scores       = neg_logits,
            pos_food_groups  = batch['pos_food_group'],
            cart_food_groups = batch['cart_food_groups'],
            cart_mask        = batch['cart_mask'],
            all_scores       = neg_logits,
        )

        # ── backward ──────────────────────────────────────────────────────────
        optimizer.zero_grad()
        total_loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        optimizer.step()
        scheduler.step()

        # ── update meters ─────────────────────────────────────────────────────
        for key in meters:
            if key in loss_dict:
                meters[key].update(loss_dict[key], n=B)

        if (step + 1) % log_every == 0:
            elapsed = time.time() - start
            lr      = scheduler.get_last_lr()[0]
            print(
                f"  Epoch {epoch:02d} | "
                f"Step {step+1:04d}/{len(loader):04d} | "
                f"Loss {meters['total'].avg:.4f} | "
                f"BPR {meters['bpr'].avg:.4f} | "
                f"Cov {meters['coverage'].avg:.4f} | "
                f"LR {lr:.2e} | "
                f"Time {format_time(elapsed)}"
            )

    return {
        'train_' + k: v.avg
        for k, v in meters.items()
    }


# ── validation ────────────────────────────────────────────────────────────────

@torch.no_grad()
def validate(
    model:     AddOnRecSys,
    loader:    DataLoader,
    criterion: CartCompleteLoss,
    device:    torch.device,
    k_values:  list = [5, 10],
) -> Dict[str, float]:
    """
    Validation — loss + HR@K + NDCG@K + MRR.
    """
    model.eval()

    loss_meter = AverageMeter('Val Loss')

    for batch in loader:
        batch = {k: v.to(device) for k, v in batch.items()}
        B     = batch['cart_mask'].size(0)

        pos_logits = model(
            cart_item_ids=batch['cart_item_idxs'],
            cart_text_embs   = batch['cart_text_embs'],
            cart_prices      = batch['cart_prices'],
            cart_food_groups = batch['cart_food_groups'],
            cart_popularity  = batch['cart_popularity'],
            cart_mask        = batch['cart_mask'],
            cand_item_id   = batch['pos_item_idx'],
            cand_text_embs   = batch['pos_text_emb'],
            cand_prices      = batch['pos_price'],
            cand_food_groups = batch['pos_food_group'],
            cand_popularity  = batch['pos_popularity'],
            cross_features   = batch['pos_cross_feats'],
            hour             = batch['hour'],
            dow              = batch['dow'],
            meal_period      = batch['meal_period'],
            restaurant_id    = batch['restaurant_id'],
            return_logit     = True,
        ).squeeze(-1)

        neg_logits = model(
            cart_item_ids   = batch['cart_item_idxs'],
            cart_text_embs   = batch['cart_text_embs'],
            cart_prices      = batch['cart_prices'],
            cart_food_groups = batch['cart_food_groups'],
            cart_popularity  = batch['cart_popularity'],
            cart_mask        = batch['cart_mask'],
            cand_item_id   = batch['neg_item_idx'],
            cand_text_embs   = batch['neg_text_emb'],
            cand_prices      = batch['neg_price'],
            cand_food_groups = batch['neg_food_group'],
            cand_popularity  = batch['neg_popularity'],
            cross_features   = batch['neg_cross_feats'],
            hour             = batch['hour'],
            dow              = batch['dow'],
            meal_period      = batch['meal_period'],
            restaurant_id    = batch['restaurant_id'],
            return_logit     = True,
        ).squeeze(-1)

        _, loss_dict = criterion(
            pos_scores       = pos_logits,
            neg_scores       = neg_logits,
            pos_food_groups  = batch['pos_food_group'],
            cart_food_groups = batch['cart_food_groups'],
            cart_mask        = batch['cart_mask'],
            all_scores       = neg_logits,
        )
        loss_meter.update(loss_dict['total'], n=B)

    # Ranking metrics
    rank_metrics = compute_ranking_metrics(
        model, loader, device, k_values
    )

    return {
        'val_loss': loss_meter.avg,
        **rank_metrics,
    }


# ── checkpoint helpers ────────────────────────────────────────────────────────

def save_checkpoint(
    model:     AddOnRecSys,
    optimizer: torch.optim.Optimizer,
    epoch:     int,
    metrics:   Dict,
    path:      str,
):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    torch.save({
        'epoch':     epoch,
        'model':     model.state_dict(),
        'optimizer': optimizer.state_dict(),
        'metrics':   metrics,
    }, path)
    print(f"  Checkpoint saved → {path}")


def load_checkpoint(
    model:     AddOnRecSys,
    optimizer: Optional[torch.optim.Optimizer],
    path:      str,
    device:    torch.device,
) -> Tuple[int, Dict]:
    ckpt = torch.load(path, map_location=device)
    model.load_state_dict(ckpt['model'])
    if optimizer is not None:
        optimizer.load_state_dict(ckpt['optimizer'])
    print(f"  Checkpoint loaded ← {path}")
    return ckpt['epoch'], ckpt['metrics']


# ── main training function ────────────────────────────────────────────────────

def train_ranker(
    # ── paths ──────────────────────────────────────────────────────────────
    train_pairs_path: str       = "outputs/train_pairs_instacart.parquet",
    val_pairs_path:  str        = "outputs/val_pairs_instacart.parquet" ,
    items_path:      str        = "outputs/items_instacart.parquet",
    text_embs_path:         str    = "outputs/text_embeddings_instacart.npy",
    pid2idx_path:           str    = "outputs/pid2idx_instacart.json",
    pmi_path:               str     = "outputs/pmi_matrix_instacart.npz",
    retrieval_ckpt_path:  str   = "artifacts/checkpoints/retrieval_tower.pt",
    checkpoint_dir:       str   = "artifacts/checkpoints",
    # ── model config ───────────────────────────────────────────────────────
    text_emb_dim:         int   = 384,
    d_model:              int   = 64,
    n_food_groups:        int   = 5,
    n_cross_features:     int   = 5,
    max_cart_len:         int   = 50,
    num_restaurants:      int   = 5000,
    backbone_dim:         int   = 256,
    # ── training config ────────────────────────────────────────────────────
    epochs:               int   = 8,
    batch_size:           int   = 32,
    lr:                   float = 1e-4,
    weight_decay:         float = 1e-2,
    warmup_pct:           float = 0.1,
    lambda_coverage:      float = 0.1,
    bpr_margin:           float = 0.0,
    use_hard_negatives:   bool  = True,
    num_workers:          int   = 0,
    log_every:            int   = 50,
    freeze_retrieval:     bool  = True,
    freeze_epochs:        int   = 5,
    resume_from:          Optional[str] = None,
    max_train_samples:    Optional[int] = None,
    max_val_samples:      Optional[int] = None,
):
    """
    Full training loop for the CartComplete Add-On Ranking model.

    Pipeline:
        1.  Build ranking dataloaders
        2.  Initialise AddOnRecSys model
        3.  Optionally load + freeze pretrained retrieval tower weights
        4.  Train with BPR + Coverage loss for `epochs` epochs
        5.  Unfreeze retrieval tower after `freeze_epochs` for fine-tuning
        6.  Validate with HR@K, NDCG@K, MRR each epoch
        7.  Save best checkpoint based on NDCG@10
        8.  Save full training history to JSON

    Two-stage training strategy:
        Stage 1 (epochs 1 → freeze_epochs):
            Retrieval tower frozen — only ranking layers train.
            Faster convergence, avoids destroying pretrained embeddings.

        Stage 2 (epochs freeze_epochs+1 → end):
            All layers unfreeze — end-to-end fine-tuning.
            Lower LR allows subtle joint optimisation.

    Output artifacts:
        artifacts/checkpoints/full_model.pt       ← best model
        artifacts/checkpoints/best_checkpoint.pt  ← alias
        artifacts/checkpoints/ranker_history.json
    """

    # ── device ────────────────────────────────────────────────────────────────
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')

    print(f"\n{'='*60}")
    print(f"  CartComplete — Add-On Ranker Training")
    print(f"  Device        : {device}")
    print(f"  Epochs        : {epochs}")
    print(f"  Batch size    : {batch_size}")
    print(f"  LR            : {lr}")
    print(f"  Lambda cov    : {lambda_coverage}")
    print(f"  Freeze epochs : {freeze_epochs if freeze_retrieval else 'None'}")
    print(f"{'='*60}\n")

    # ── dataloaders ───────────────────────────────────────────────────────────
    print("Building ranking dataloaders...")
    collator = get_collator(mode='ranking', dynamic_padding=False)

    train_loader, val_loader = build_ranking_dataloaders(
        train_pairs_path  = train_pairs_path,
        val_pairs_path    = val_pairs_path,
        items_path        = items_path,
        text_embs_path    = text_embs_path,
        pid2idx_path      = pid2idx_path,
        pmi_path          = pmi_path,
        max_cart_len      = max_cart_len,
        n_negatives       = 1,
        batch_size        = batch_size,
        num_workers       = num_workers,
        max_train_samples = max_train_samples,
        max_val_samples   = max_val_samples,
    )

    train_loader.collate_fn = collator
    val_loader.collate_fn   = collator

    # ── model ─────────────────────────────────────────────────────────────────
    print("\nInitialising AddOnRecSys model...")

    with open(pid2idx_path) as f:
        pid2idx = json.load(f)
    n_items = len(pid2idx)

    model = AddOnRecSys(
        num_items=n_items,
        text_emb_dim      = text_emb_dim,
        d_model           = d_model,
       
        n_cross_features  = n_cross_features,
        num_restaurants   = num_restaurants,
        backbone_dim      = backbone_dim,
        max_cart_len      = max_cart_len,
    ).to(device)

    total_params = sum(p.numel() for p in model.parameters())
    print(f"  Total parameters : {total_params:,}")

    # ── load pretrained retrieval tower ───────────────────────────────────────
    if os.path.exists(retrieval_ckpt_path):
        print(f"\nLoading pretrained retrieval tower from:")
        print(f"  {retrieval_ckpt_path}")
        ckpt = torch.load(retrieval_ckpt_path, map_location=device)
        # Load only matching keys from retrieval tower
        model_dict    = model.state_dict()
        pretrained    = {
            k: v for k, v in ckpt['model'].items()
            if k in model_dict and model_dict[k].shape == v.shape
        }
        model_dict.update(pretrained)
        model.load_state_dict(model_dict)
        print(f"  Loaded {len(pretrained):,} / "
              f"{len(model_dict):,} weight tensors")
    else:
        print(f"\nNo retrieval checkpoint found at {retrieval_ckpt_path}")
        print(f"  Training ranker from scratch.")

    # ── freeze retrieval tower for stage 1 ───────────────────────────────────
    if freeze_retrieval:
        print(f"\nFreezing retrieval tower for first {freeze_epochs} epochs...")
        for name, param in model.named_parameters():
            if 'two_tower' in name or 'item_encoder' in name:
                param.requires_grad = False
        frozen = sum(
            p.numel() for p in model.parameters()
            if not p.requires_grad
        )
        print(f"  Frozen parameters : {frozen:,}")

    # ── optimiser & scheduler ─────────────────────────────────────────────────
    optimizer = AdamW(
        filter(lambda p: p.requires_grad, model.parameters()),
        lr           = lr,
        weight_decay = weight_decay,
    )

    total_steps = epochs * len(train_loader)
    scheduler   = OneCycleLR(
        optimizer,
        max_lr          = lr,
        total_steps     = total_steps,
        pct_start       = warmup_pct,
        anneal_strategy = 'cos',
    )

    # ── loss ──────────────────────────────────────────────────────────────────
    criterion = CartCompleteLoss(
        lambda_coverage    = lambda_coverage,
        bpr_margin         = bpr_margin,
        use_hard_negatives = use_hard_negatives,
        n_food_groups      = n_food_groups,
    )

    # ── optionally resume ─────────────────────────────────────────────────────
    start_epoch    = 0
    best_ndcg10    = 0.0
    history        = []

    if resume_from and os.path.exists(resume_from):
        print(f"\nResuming from {resume_from}...")
        start_epoch, prev_metrics = load_checkpoint(
            model, optimizer, resume_from, device
        )
        best_ndcg10 = prev_metrics.get('NDCG@10', 0.0)
        start_epoch += 1

    # ── training loop ─────────────────────────────────────────────────────────
    print(f"\nStarting ranker training from epoch {start_epoch + 1}...\n")
    train_start = time.time()

    for epoch in range(start_epoch, epochs):
        print(f"\n{'─'*60}")
        print(f"  Epoch {epoch+1}/{epochs}")
        print(f"{'─'*60}")

        # ── unfreeze retrieval tower after freeze_epochs ──────────────────────
        if freeze_retrieval and epoch == freeze_epochs:
            print(f"\n  Unfreezing all parameters for end-to-end fine-tuning...")
            for param in model.parameters():
                param.requires_grad = True
            # Rebuild optimiser with lower LR for fine-tuning
            optimizer = AdamW(
                model.parameters(),
                lr           = lr * 0.1,
                weight_decay = weight_decay,
            )
            remaining_steps = (epochs - epoch) * len(train_loader)
            scheduler = OneCycleLR(
                optimizer,
                max_lr          = lr * 0.1,
                total_steps     = remaining_steps,
                pct_start       = 0.05,
                anneal_strategy = 'cos',
            )
            print(f"  Fine-tuning LR: {lr * 0.1:.2e}")

        # ── train ─────────────────────────────────────────────────────────────
        train_metrics = train_one_epoch(
            model     = model,
            loader    = train_loader,
            optimizer = optimizer,
            scheduler = scheduler,
            criterion = criterion,
            device    = device,
            epoch     = epoch + 1,
            log_every = log_every,
        )

        # ── validate ──────────────────────────────────────────────────────────
        print(f"\n  Validating...")
        val_metrics = {
            'val_loss': 0,
            'HR@5': 0,
            'HR@10': 0,
            'NDCG@5': 0,
            'NDCG@10': 0,
            'MRR': 0,
        }

        torch.cuda.empty_cache()

        # ── merge + log metrics ───────────────────────────────────────────────
        epoch_metrics = {
            'epoch': epoch + 1,
            **train_metrics,
            **val_metrics,
        }
        history.append(epoch_metrics)

        print(f"\n  Epoch {epoch+1} Summary:")
        print(f"    Train Loss  : {train_metrics['train_total']:.4f}")
        print(f"    Train BPR   : {train_metrics['train_bpr']:.4f}")
        print(f"    Train Cov   : {train_metrics['train_coverage']:.4f}")
        print(f"    Val Loss    : {val_metrics['val_loss']:.4f}")
        print(f"    HR@5        : {val_metrics.get('HR@5',    0):.4f}")
        print(f"    HR@10       : {val_metrics.get('HR@10',   0):.4f}")
        print(f"    NDCG@5      : {val_metrics.get('NDCG@5',  0):.4f}")
        print(f"    NDCG@10     : {val_metrics.get('NDCG@10', 0):.4f}")
        print(f"    MRR         : {val_metrics.get('MRR',     0):.4f}")

        # ── save best checkpoint ──────────────────────────────────────────────
        ndcg10 = val_metrics.get('NDCG@10', 0.0)
        if ndcg10 > best_ndcg10:
            best_ndcg10 = ndcg10
            # Save as both full_model.pt and best_checkpoint.pt
            for ckpt_name in ['full_model.pt', 'best_checkpoint.pt']:
                save_checkpoint(
                    model     = model,
                    optimizer = optimizer,
                    epoch     = epoch,
                    metrics   = epoch_metrics,
                    path      = os.path.join(checkpoint_dir, ckpt_name),
                )
            print(f"  ✓ New best NDCG@10: {best_ndcg10:.4f}")

        # ── save latest ───────────────────────────────────────────────────────
        save_checkpoint(
            model     = model,
            optimizer = optimizer,
            epoch     = epoch,
            metrics   = epoch_metrics,
            path      = os.path.join(checkpoint_dir, 'ranker_latest.pt'),
        )

    # ── save history ──────────────────────────────────────────────────────────
    history_path = os.path.join(checkpoint_dir, 'ranker_history.json')
    os.makedirs(checkpoint_dir, exist_ok=True)
    with open(history_path, 'w') as f:
        json.dump(history, f, indent=2)
    print(f"\n  Training history saved → {history_path}")

    total_time = time.time() - train_start
    print(f"\n{'='*60}")
    print(f"  Ranker Training Complete")
    print(f"  Total time   : {format_time(total_time)}")
    print(f"  Best NDCG@10 : {best_ndcg10:.4f}")
    print(f"  Best model   → {checkpoint_dir}/full_model.pt")
    print(f"{'='*60}\n")

    return history


# ── entry point ───────────────────────────────────────────────────────────────

if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser(
        description="Train CartComplete Add-On Ranker"
    )

    # Paths
    # Paths
    parser.add_argument('--train_pairs',
                    default="outputs/train_pairs_instacart.parquet")

    parser.add_argument('--val_pairs',
                    default="outputs/val_pairs_instacart.parquet")

    parser.add_argument('--items',
                    default="outputs/items_instacart.parquet")

    parser.add_argument('--text_embs',
                    default="outputs/text_embeddings_instacart.npy")

    parser.add_argument('--pid2idx',
                    default="outputs/pid2idx_instacart.json")

    parser.add_argument('--pmi_path',
                    default="outputs/pmi_matrix_instacart.npz")

    parser.add_argument('--retrieval_ckpt',
                    default="artifacts/checkpoints/retrieval_tower.pt")

    parser.add_argument('--checkpoint_dir',
                    default="artifacts/checkpoints")

    # Model
    parser.add_argument('--text_emb_dim',    type=int,   default=384)
    parser.add_argument('--d_model',         type=int,   default=64)
    parser.add_argument('--n_food_groups',   type=int,   default=5)
    parser.add_argument('--n_cross_features',type=int,   default=5)
    parser.add_argument('--num_restaurants', type=int,   default=5000)
    parser.add_argument('--backbone_dim',    type=int,   default=256)
    parser.add_argument('--max_cart_len',    type=int,   default=50)

    # Training
    parser.add_argument('--epochs',          type=int,   default=8)
    parser.add_argument('--batch_size',      type=int,   default=32)
    parser.add_argument('--lr',              type=float, default=1e-4)
    parser.add_argument('--weight_decay',    type=float, default=1e-2)
    parser.add_argument('--warmup_pct',      type=float, default=0.1)
    parser.add_argument('--lambda_coverage', type=float, default=0.1)
    parser.add_argument('--bpr_margin',      type=float, default=0.0)
    parser.add_argument('--freeze_epochs',   type=int,   default=5)
    parser.add_argument('--no_freeze',       action='store_true')
    parser.add_argument('--no_hard_neg',     action='store_true')
    parser.add_argument('--num_workers',     type=int,   default=4)
    parser.add_argument('--log_every',       type=int,   default=50)
    parser.add_argument('--resume_from',     type=str,   default=None)
    parser.add_argument('--max_train_samples', type=int, default=None)
    parser.add_argument('--max_val_samples',   type=int, default=None)

    args = parser.parse_args()

    train_ranker(
        train_pairs_path   = args.train_pairs,
        val_pairs_path     = args.val_pairs,
        items_path         = args.items,
        text_embs_path     = args.text_embs,
        pid2idx_path       = args.pid2idx,
        pmi_path           = args.pmi_path,
        retrieval_ckpt_path= args.retrieval_ckpt,
        checkpoint_dir     = args.checkpoint_dir,
        text_emb_dim       = args.text_emb_dim,
        d_model            = args.d_model,
        n_food_groups      = args.n_food_groups,
        n_cross_features   = args.n_cross_features,
        num_restaurants    = args.num_restaurants,
        backbone_dim       = args.backbone_dim,
        max_cart_len       = args.max_cart_len,
        epochs             = args.epochs,
        batch_size         = args.batch_size,
        lr                 = args.lr,
        weight_decay       = args.weight_decay,
        warmup_pct         = args.warmup_pct,
        lambda_coverage    = args.lambda_coverage,
        bpr_margin         = args.bpr_margin,
        freeze_retrieval   = not args.no_freeze,
        freeze_epochs      = args.freeze_epochs,
        use_hard_negatives = not args.no_hard_neg,
        num_workers        = args.num_workers,
        log_every          = args.log_every,
        resume_from        = args.resume_from,
        max_train_samples  = args.max_train_samples,
        max_val_samples    = args.max_val_samples,
    )